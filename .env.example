# Server Configuration
PORT=3000
NODE_ENV=development
APP_NAME=FutureGuide

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/futureguide
DB_NAME=futureguide

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Privacy & Security
GRADIENT_CLIPPING_NORM=1.0
DIFFERENTIAL_PRIVACY_EPSILON=0.8
DIFFERENTIAL_PRIVACY_DELTA=0.00001
FEDERATED_ROUNDS=20

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Application Settings
MAX_STREAM_RECOMMENDATIONS=3
MAX_COLLEGE_MATCHES=5
MAX_JOB_RECOMMENDATIONS=4
STREAMS=["Science","Commerce","Arts"]
TEMPERATURE_SCALING=1.0
